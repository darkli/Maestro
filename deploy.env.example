# ============================================================
# Maestro VPS 一键部署配置
# 复制为 deploy.env 并填入你的信息，然后运行 bash deploy.sh
# ============================================================

# ---- VPS 连接 ----
VPS_HOST=""
VPS_PORT="22"
VPS_USER="root"
VPS_PASSWORD=""             # SSH 密码（需安装 sshpass: brew install sshpass）
VPS_SSH_KEY=""              # SSH 私钥路径（如 ~/.ssh/id_rsa），留空则密码登录
                            # 优先级: SSH Key > 密码 > 交互式输入

# ---- 部署方式与目录 ----
DEPLOY_METHOD="rsync"       # rsync | git
DEPLOY_DIR="/opt/maestro"
GIT_REPO=""                 # git 模式需要填写仓库地址
GIT_BRANCH="main"

# ============================================================
# Claude Code 认证（内层编码工具）
# ============================================================
# Claude Code 通过 subprocess 调用，认证在 VPS 上完成。
# 首次部署完成后，脚本会引导你 SSH 到 VPS 执行 claude login 完成授权。
# 部署脚本不再备份、恢复或删除 ~/.claude/；是否保留由工具卸载行为决定。
#
# 如果你更希望用 API Key（按 token 计费，不走订阅），
# 可以填下面这行，部署脚本会自动配置环境变量，无需 claude login。
# ============================================================
ANTHROPIC_API_KEY=""        # 可选，留空则部署后引导 claude login

# ============================================================
# Manager Agent（外层决策 AI）
# ============================================================
# Manager 是"指挥官"，分析 Claude Code 的输出并决定下一步。
# 它通过 API 调用 LLM，支持以下 provider。
#
# 只需填写下方 4 个变量。选择一个 provider，对照下面的说明填入。
# ============================================================

MANAGER_PROVIDER="deepseek"
MANAGER_MODEL="deepseek-chat"
MANAGER_API_KEY=""
MANAGER_BASE_URL=""         # 大多数 provider 自动推断，无需填写

# ============================================================
# 各 Provider 配置参考（选一个填到上面的 4 个变量中）
# ============================================================
#
# ┌─────────────────────────────────────────────────────────────
# │ 1. DeepSeek（推荐，性价比最高）
# │
# │    MANAGER_PROVIDER="deepseek"
# │    MANAGER_MODEL="deepseek-chat"          # 通用对话，便宜
# │    # MANAGER_MODEL="deepseek-reasoner"    # 推理增强，贵 4 倍
# │    MANAGER_API_KEY="sk-xxx"               # https://platform.deepseek.com/api_keys
# │    MANAGER_BASE_URL=""                    # 留空，自动用 https://api.deepseek.com
# │
# │    定价: deepseek-chat ¥1/百万token（约 $0.14），极其便宜
# │
# ├─────────────────────────────────────────────────────────────
# │ 2. OpenAI（GPT 系列）
# │
# │    MANAGER_PROVIDER="openai"
# │    MANAGER_MODEL="gpt-4o"                 # 最强
# │    # MANAGER_MODEL="gpt-4o-mini"          # 便宜够用
# │    # MANAGER_MODEL="gpt-4.1"              # 最新
# │    # MANAGER_MODEL="gpt-4.1-mini"         # 最新且便宜
# │    MANAGER_API_KEY="sk-xxx"               # https://platform.openai.com/api-keys
# │    MANAGER_BASE_URL=""                    # 留空，默认 https://api.openai.com/v1
# │
# │    定价: gpt-4o-mini $0.15/$0.6/M tokens, gpt-4o $2.5/$10/M tokens
# │
# ├─────────────────────────────────────────────────────────────
# │ 3. Anthropic（Claude API，用原生 SDK 调用）
# │
# │    MANAGER_PROVIDER="anthropic"
# │    MANAGER_MODEL="claude-sonnet-4-20250514"       # Sonnet 4
# │    # MANAGER_MODEL="claude-3-5-sonnet-20241022"   # Sonnet 3.5
# │    MANAGER_API_KEY="sk-ant-xxx"            # https://console.anthropic.com/
# │    MANAGER_BASE_URL=""                     # 不需要
# │
# │    注意: anthropic provider 使用原生 Anthropic SDK，不走 OpenAI 兼容协议。
# │    定价: Sonnet $3/$15/M tokens
# │
# ├─────────────────────────────────────────────────────────────
# │ 4. Google Gemini
# │
# │    MANAGER_PROVIDER="gemini"
# │    MANAGER_MODEL="gemini-2.0-flash"       # 快速便宜
# │    # MANAGER_MODEL="gemini-2.5-pro"       # 最强
# │    MANAGER_API_KEY="AIzaSyxxx"            # https://aistudio.google.com/apikey
# │    MANAGER_BASE_URL=""                    # 留空，自动用 Google OpenAI 兼容端点
# │
# │    定价: flash $0.1/$0.4/M tokens, 2.5-pro $1.25/$10/M tokens
# │
# ├─────────────────────────────────────────────────────────────
# │ 5. Ollama（本地模型，完全免费）
# │
# │    MANAGER_PROVIDER="ollama"
# │    MANAGER_MODEL="qwen2.5:14b"            # 推荐 14B 以上
# │    # MANAGER_MODEL="llama3.1:8b"
# │    # MANAGER_MODEL="deepseek-r1:14b"
# │    MANAGER_API_KEY=""                      # 留空，不需要
# │    MANAGER_BASE_URL=""                     # 留空，自动用 http://localhost:11434/v1
# │
# │    前提: VPS 上已安装并运行 Ollama，且已 pull 对应模型。
# │    适合: 有 GPU 的机器或不想花钱的场景。JSON 输出能力较弱，
# │    建议用 14B+ 参数的模型。
# │
# ├─────────────────────────────────────────────────────────────
# │ 6. Azure OpenAI
# │
# │    MANAGER_PROVIDER="azure"
# │    MANAGER_MODEL="your-deployment-name"    # Azure 部署名（非模型名）
# │    MANAGER_API_KEY="xxx"                   # Azure Portal → 资源 → 密钥
# │    MANAGER_BASE_URL="https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT/v1"
# │
# │    注意: Azure 必须填 MANAGER_BASE_URL，格式见上。
# │
# ├─────────────────────────────────────────────────────────────
# │ 7. 任意 OpenAI 兼容服务（OpenRouter / Together / Groq / 中转站等）
# │
# │    MANAGER_PROVIDER="openai"              # 统一用 openai
# │    MANAGER_MODEL="模型名"                  # 按服务商文档填
# │    MANAGER_API_KEY="xxx"
# │    MANAGER_BASE_URL="https://xxx/v1"      # 服务商的 API 端点
# │
# │    示例 - OpenRouter:
# │      MANAGER_PROVIDER="openai"
# │      MANAGER_MODEL="anthropic/claude-sonnet-4"
# │      MANAGER_API_KEY="sk-or-xxx"
# │      MANAGER_BASE_URL="https://openrouter.ai/api/v1"
# │
# │    示例 - Groq:
# │      MANAGER_PROVIDER="openai"
# │      MANAGER_MODEL="llama-3.3-70b-versatile"
# │      MANAGER_API_KEY="gsk_xxx"
# │      MANAGER_BASE_URL="https://api.groq.com/openai/v1"
# │
# │    示例 - Together AI:
# │      MANAGER_PROVIDER="openai"
# │      MANAGER_MODEL="meta-llama/Llama-3.3-70B-Instruct-Turbo"
# │      MANAGER_API_KEY="xxx"
# │      MANAGER_BASE_URL="https://api.together.xyz/v1"
# │
# └─────────────────────────────────────────────────────────────

# ---- Telegram Bot（可选，留空则跳过） ----
TELEGRAM_BOT_TOKEN=""       # 从 @BotFather 获取
TELEGRAM_CHAT_ID=""         # 从 @userinfobot 获取你的 chat_id

# ---- 网络配置 ----
# 系统级 IPv4 优先（通过 /etc/gai.conf 实现，影响 VPS 上所有进程）
# true  = 部署时配置 gai.conf，DNS 解析优先返回 IPv4 地址（推荐）
# false = 不修改系统网络配置
#
# 双栈 VPS 默认优先 IPv6（RFC 6724），但很多 API 服务商根据 IPv6 误判地区，
# 导致 Claude Code、Codex CLI 等子进程访问 API 失败。
# 开启后所有进程（Manager + Claude Code + Codex）统一走 IPv4，且不禁用 IPv6。
PREFER_IPV4="true"

# ---- 运行用户 ----
# Claude Code 禁止 root 使用 --dangerously-skip-permissions（安全限制），
# 因此 Maestro 需要以非 root 用户运行。部署脚本会自动创建此用户。
MAESTRO_RUN_USER="viber"    # 运行 Maestro 服务的系统用户
MAESTRO_RUN_PASSWORD=""     # 用户密码（留空则自动生成 16 位字母数字密码，避免特殊字符兼容问题）

# ---- 高级选项 ----
SETUP_SYSTEMD="true"        # 是否创建 systemd 服务（需 Telegram 已配置）
