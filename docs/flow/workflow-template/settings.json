{
  "_workflow_version": "2.0.0",
  "_comment": "Claude Code Hook 配置模板。将此文件复制到项目根目录的 .claude/settings.json。Hook 脚本路径指向 .claude/hooks/ 目录。如需适配，请参考 hooks/README.md。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/git-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-format.sh",
            "timeout": 60
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-related-tests.sh",
            "async": true,
            "timeout": 300
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify-completion.sh",
            "async": true,
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/generate-report.sh",
            "async": true,
            "timeout": 30
          }
        ]
      }
    ]
  }
}
